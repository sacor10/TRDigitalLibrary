{
  "name": "tr-digital-library",
  "version": "0.1.0",
  "private": true,
  "description": "A digital library of Theodore Roosevelt's complete works and correspondence.",
  "license": "MIT",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "bootstrap": "node scripts/ensure-install.mjs",
    "predev": "node scripts/ensure-install.mjs",
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm run dev -w server\" \"npm run dev -w client\"",
    "prebuild": "node scripts/ensure-install.mjs",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "pretest": "node scripts/ensure-install.mjs",
    "test": "npm run test -w shared --if-present && npm run test -w server && npm run test -w client",
    "preingest": "node scripts/ensure-install.mjs",
    "ingest": "node scripts/run-build-ingest.mjs",
    "ingest-loc": "npm run ingest-loc -w server --",
    "ingest-trc": "npm run ingest-trc -w server --",
    "ingest-tei": "npm run ingest-tei -w server --",
    "upload-library-to-turso": "npm run upload-library-to-turso -w server --",
    "topic-model": "node scripts/run-topic-model.mjs",
    "sentiment": "node scripts/run-sentiment.mjs",
    "prelint": "node scripts/ensure-install.mjs",
    "lint": "eslint \"{shared,server,client}/src/**/*.{ts,tsx}\"",
    "preformat": "node scripts/ensure-install.mjs",
    "format": "prettier --write \"{shared,server,client}/src/**/*.{ts,tsx,css,json}\" \"*.{json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "3.6.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "netlify-plugin-cache": "^1.0.3",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "serverless-http": "^3.2.0"
  }
}
